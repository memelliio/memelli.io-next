# Postgres connection to control_store (the one database). Set in Railway, never commit a real value.
DATABASE_URL=postgresql://user:pass@host:5432/railway
# Set to "disable" to turn off SSL (local dev). Default uses SSL with rejectUnauthorized:false.
PGSSL=
# Optional: Groq key for the Ask Memelli brain. If absent, chat returns a graceful fallback.
GROQ_API_KEY=
